doctype html
html
  head
    title= title
    style.
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
          'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
          sans-serif;
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100vh;
        background-color: #F9AE9F;
      }
      h1 {
        font-size: 70px;
        color: white;
      }
      p {
        font-size: 30px;
        color: white;
      }
      .container {
        justify-content: center;
        text-align: center;
      }
      .svgStyle {
        margin-top: 2em;
        width: 200px;
        filter: invert(100%) sepia(100%) saturate(0%) hue-rotate(108deg) brightness(104%) contrast(104%);
      }
  body
    .container
      h1= title
      p Internal server error!
      img.svgStyle.image(src='/icons/500Icon.svg')
